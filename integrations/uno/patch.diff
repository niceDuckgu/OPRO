+class DoubleStreamBlockOproProcessor:
+    """Drop-in attention processor that applies OPRO on the image stream."""
+    def __init__(self, layer_idx: int):
+        self.layer_idx = int(layer_idx)
+
+    def __call__(self, attn, q, k, v, pe, parent_dit=None, **kw):
+        from uno.flux.math import apply_rope
+        q, k = apply_rope(q, k, pe)
+
+        ctx = getattr(parent_dit, "_opro_ctx", None) if parent_dit is not None else None
+        if ctx is not None:
+            modules   = ctx["modules"]
+            panel_ids = ctx["img_panel_ids"].to(q.device).long()
+            # Image tokens occupy the trailing slice in UNO's joint Q/K.
+            txt_len = parent_dit.params.txt_in_dim   # text-stream length
+            img_start = txt_len
+            img_end   = img_start + panel_ids.shape[1]
+            if img_end <= q.shape[2]:
+                q_img, k_img = modules[self.layer_idx].apply_to_qk(
+                    q[:, :, img_start:img_end, :],
+                    k[:, :, img_start:img_end, :], panel_ids,
+                )
+                q = q.clone(); k = k.clone()
+                q[:, :, img_start:img_end, :] = q_img
+                k[:, :, img_start:img_end, :] = k_img
+
+        return scaled_dot_product_attention(q, k, v)
+
+
+def install_opro_processors(dit):
+    """Walk all DoubleStreamBlocks and install OPRO-aware processors."""
+    for i, block in enumerate(dit.double_blocks):
+        block.set_processor(DoubleStreamBlockOproProcessor(layer_idx=i))
+    for j, block in enumerate(dit.single_blocks, start=len(dit.double_blocks)):
+        block.set_processor(DoubleStreamBlockOproProcessor(layer_idx=j))
